{
    "name": "api-adocao-pets",
    "version": "1.0.0",
    "description": "API RESTful para sistema de adoção de animais de estimação",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write \"src/**/*.js\"",
        "db:setup": "node src/database/setup.js",
        "db:seed": "node src/database/seed.js",
        "test": "jest --runInBand",
        "test:coverage": "jest --coverage --runInBand"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/tests/unit/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/database/setup.js",
            "!src/database/seed.js"
        ]
    },
    "dependencies": {
        "bcrypt": "^5.1.1",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "mysql2": "^3.9.7"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "jest": "^30.4.2",
        "nodemon": "^3.1.2",
        "prettier": "^3.2.5"
    }
}
{
    "info": {
        "_postman_id": "4c2c4b02-ef0f-4f2c-9b0d-0c8d1d4d8f90",
        "name": "API Adocao Pets",
        "description": "Colecao da API de adocao de pets com autenticacao JWT, CRUD e adocao.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login Admin",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin@pets.com\",\n  \"password\": \"admin123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "login"
                            ]
                        },
                        "description": "Faz login como admin e grava o token em adminToken."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const data = pm.response.json();",
                                    "if (data.token) {",
                                    "    pm.environment.set('adminToken', data.token);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Login Adopter",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"joao@email.com\",\n  \"password\": \"senha123\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "login"
                            ]
                        },
                        "description": "Faz login como adopter e grava o token em adopterToken."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "const data = pm.response.json();",
                                    "if (data.token) {",
                                    "    pm.environment.set('adopterToken', data.token);",
                                    "}"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
